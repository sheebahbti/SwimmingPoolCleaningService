DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/swimming_pool_dev"
JWT_SECRET="change-this-to-a-strong-random-secret"
PORT=3000

# Email (Nodemailer) — optional, emails are skipped if not configured
# Use Mailtrap for testing (catches emails instead of sending to real inboxes)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
SMTP_FROM=Pool Cleaning Service <noreply@poolservice.com>
